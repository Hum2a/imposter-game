# Client (embedded in Vite bundle)
VITE_DISCORD_CLIENT_ID=
VITE_PARTYKIT_HOST=localhost:1999

# Full URL to POST { code } → { access_token } (Cloudflare Worker). Leave empty for same-origin /api/token.
# VITE_DISCORD_TOKEN_URL=https://imposter-discord-oauth.your-subdomain.workers.dev/api/token

# Dev token exchange — used only by Vite dev server (vite-plugin-discord-token), never bundled
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# If Discord returns invalid_grant and asks for redirect_uri, set this to your registered redirect
# DISCORD_REDIRECT_URI=

# Local UI without Discord iframe: npm run dev with this set to 1
# VITE_DISCORD_MOCK=1

# Optional — website / PWA: anonymous Supabase users + web_profiles table (see supabase/migrations)
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# Any one of the following (first match wins in code):
# VITE_SUPABASE_ANON_KEY=eyJ...                    # legacy JWT “anon” key
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_...   # name used in some Supabase UI docs
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_...

# Optional — Plausible Analytics (privacy-friendly; no cookie banner typical setup)
# VITE_PLAUSIBLE_DOMAIN=your.site.com
# VITE_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js
