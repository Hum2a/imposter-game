# Staging deploy template — copy to `.env.deploy.staging` (gitignored) and fill in.
# Deploy: DEPLOY_ENV_FILE=.env.deploy.staging node scripts/deploy.mjs all
# See docs/STAGING.md

CF_PAGES_PROJECT_NAME=your-pages-project-staging

# Staging Partykit host (hostname only, no https://)
VITE_PARTYKIT_HOST=

# Optional: second Discord app for Activity QA
VITE_DISCORD_CLIENT_ID=

# Staging Worker token endpoint (full URL ending in /api/token if needed)
# VITE_DISCORD_TOKEN_URL=https://your-staging-worker.workers.dev/api/token

# Plausible: use a staging site id or leave unset
# VITE_PLAUSIBLE_DOMAIN=staging.yourdomain.com

# Worker deploy vars (same keys as production example)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# DISCORD_REDIRECT_URI=

# Partykit: keep false for staging unless testing verification
JOIN_VERIFY=false
WORD_PROFANITY_FILTER=false
